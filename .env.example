# Server
PORT=5000
# IMPORTANT: keep this as "development" for local work. Auth cookies are
# marked `secure` (HTTPS-only) whenever NODE_ENV=production, so if you flip
# this to production on a local http:// server, login will silently appear
# to succeed but no cookies will actually be stored by the browser.
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase (Project Settings -> API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Paystack (Settings -> API Keys & Webhooks)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Rate limiting (general API; auth routes have their own stricter limiter)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Logging (optional) - one of: error, warn, info, http, debug
LOG_LEVEL=debug
