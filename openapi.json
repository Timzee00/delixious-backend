{
  "openapi": "3.0.3",
  "info": {
    "title": "Delixious API",
    "version": "1.0.0",
    "description": "Multi-restaurant food ordering platform API. Auth uses httpOnly cookies (access_token, refresh_token) plus a double-submit CSRF cookie (csrf_token) - send its value back as the X-CSRF-Token header on any non-GET request."
  },
  "servers": [{ "url": "/api" }],
  "tags": [
    { "name": "Auth" },
    { "name": "Restaurants" },
    { "name": "Menu" },
    { "name": "Search" },
    { "name": "Uploads" },
    { "name": "Cart" },
    { "name": "Orders" },
    { "name": "Payments" },
    { "name": "Delivery" },
    { "name": "Reviews" },
    { "name": "Notifications" }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access_token",
        "description": "Set automatically as an httpOnly cookie by /auth/login or /auth/signup."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": { "error": { "type": "string" }, "code": { "type": "string" } }
      },
      "Profile": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "full_name": { "type": "string" },
          "phone": { "type": "string" },
          "role": { "type": "string", "enum": ["customer", "restaurant_owner", "delivery_agent", "admin"] },
          "avatar_url": { "type": "string" }
        }
      },
      "Restaurant": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "cuisine_type": { "type": "string" },
          "address": { "type": "string" },
          "logo_url": { "type": "string" },
          "cover_image_url": { "type": "string" },
          "is_open": { "type": "boolean" },
          "rating_avg": { "type": "number" },
          "rating_count": { "type": "integer" }
        }
      },
      "MenuItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "restaurant_id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number" },
          "image_url": { "type": "string" },
          "category": { "type": "string" },
          "is_available": { "type": "boolean" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "status": {
            "type": "string",
            "enum": ["pending", "confirmed", "preparing", "out_for_delivery", "delivered", "cancelled"]
          },
          "subtotal": { "type": "number" },
          "delivery_fee": { "type": "number" },
          "total_amount": { "type": "number" },
          "delivery_address": { "type": "string" },
          "payment_status": { "type": "string", "enum": ["pending", "paid", "failed", "refunded"] }
        }
      },
      "Review": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "order_id": { "type": "string", "format": "uuid" },
          "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
          "comment": { "type": "string" }
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "type": { "type": "string", "enum": ["general", "order_update", "payment", "promo"] },
          "is_read": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Validation failed",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "Unauthorized": {
        "description": "Not authenticated / session expired",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "Forbidden": {
        "description": "Not allowed to perform this action",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    }
  },
  "paths": {
    "/auth/signup": {
      "post": {
        "tags": ["Auth"],
        "summary": "Create an account (customer, restaurant_owner, or delivery_agent)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password", "full_name"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "minLength": 8 },
                  "full_name": { "type": "string" },
                  "phone": { "type": "string" },
                  "role": { "type": "string", "enum": ["customer", "restaurant_owner", "delivery_agent"] }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Account created" }, "400": { "$ref": "#/components/responses/BadRequest" } }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Log in - sets httpOnly access/refresh cookies + a readable CSRF cookie",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": { "email": { "type": "string" }, "password": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Logged in" }, "401": { "$ref": "#/components/responses/Unauthorized" } }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Exchange the refresh_token cookie for a new access token",
        "responses": { "200": { "description": "Session refreshed" }, "401": { "$ref": "#/components/responses/Unauthorized" } }
      }
    },
    "/auth/logout": {
      "post": { "tags": ["Auth"], "summary": "Log out and clear auth cookies", "responses": { "200": { "description": "Logged out" } } }
    },
    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get the current user + profile",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "Current user" }, "401": { "$ref": "#/components/responses/Unauthorized" } }
      }
    },
    "/auth/profile": {
      "put": {
        "tags": ["Auth"],
        "summary": "Update your profile",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/Profile" } }
          }
        },
        "responses": { "200": { "description": "Updated" }, "400": { "$ref": "#/components/responses/BadRequest" } }
      }
    },
    "/restaurants": {
      "get": {
        "tags": ["Restaurants"],
        "summary": "Browse/search restaurants",
        "parameters": [
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "cuisine", "in": "query", "schema": { "type": "string" } },
          { "name": "is_open", "in": "query", "schema": { "type": "boolean" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated restaurant list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "restaurants": { "type": "array", "items": { "$ref": "#/components/schemas/Restaurant" } },
                    "total": { "type": "integer" },
                    "page": { "type": "integer" },
                    "limit": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Restaurants"],
        "summary": "Create a restaurant (restaurant_owner/admin)",
        "security": [{ "cookieAuth": [] }],
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Restaurant" } } } },
        "responses": { "201": { "description": "Created" }, "403": { "$ref": "#/components/responses/Forbidden" } }
      }
    },
    "/restaurants/mine": {
      "get": {
        "tags": ["Restaurants"],
        "summary": "List restaurants you own",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "Your restaurants" } }
      }
    },
    "/restaurants/{id}": {
      "get": {
        "tags": ["Restaurants"],
        "summary": "Restaurant detail",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Restaurant" }, "404": { "$ref": "#/components/responses/NotFound" } }
      },
      "put": {
        "tags": ["Restaurants"],
        "summary": "Update your restaurant",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" }, "403": { "$ref": "#/components/responses/Forbidden" } }
      },
      "delete": {
        "tags": ["Restaurants"],
        "summary": "Delete your restaurant",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Deleted" }, "403": { "$ref": "#/components/responses/Forbidden" } }
      }
    },
    "/restaurants/{id}/toggle-open": {
      "patch": {
        "tags": ["Restaurants"],
        "summary": "Toggle open/closed",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Toggled" } }
      }
    },
    "/restaurants/{id}/menu": {
      "get": {
        "tags": ["Menu"],
        "summary": "Get a restaurant's menu, grouped by category",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Menu items" } }
      },
      "post": {
        "tags": ["Menu"],
        "summary": "Add a menu item (owner only)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/MenuItem" } } } },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/restaurants/{id}/reviews": {
      "get": {
        "tags": ["Reviews"],
        "summary": "Public reviews for a restaurant",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Reviews" } }
      }
    },
    "/restaurants/{id}/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "Incoming orders for your restaurant (owner only)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Orders" } }
      }
    },
    "/menu-items/{id}": {
      "put": {
        "tags": ["Menu"],
        "summary": "Update a menu item",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Menu"],
        "summary": "Delete a menu item",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/menu-items/{id}/toggle-availability": {
      "patch": {
        "tags": ["Menu"],
        "summary": "Toggle sold-out status",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Toggled" } }
      }
    },
    "/search": {
      "get": {
        "tags": ["Search"],
        "summary": "Combined restaurant + dish search",
        "parameters": [{ "name": "q", "in": "query", "required": true, "schema": { "type": "string", "minLength": 2 } }],
        "responses": { "200": { "description": "Search results" } }
      }
    },
    "/uploads": {
      "post": {
        "tags": ["Uploads"],
        "summary": "Upload an image (logo, cover, menu-item, or avatar) - resized and compressed to WebP server-side",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" },
                  "category": { "type": "string", "enum": ["logo", "cover", "menu-item", "avatar"] }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Uploaded", "content": { "application/json": { "schema": { "type": "object", "properties": { "url": { "type": "string" } } } } } } }
      }
    },
    "/cart": {
      "get": { "tags": ["Cart"], "summary": "View your cart", "security": [{ "cookieAuth": [] }], "responses": { "200": { "description": "Cart" } } },
      "delete": { "tags": ["Cart"], "summary": "Clear your cart", "security": [{ "cookieAuth": [] }], "responses": { "200": { "description": "Cleared" } } }
    },
    "/cart/items": {
      "post": {
        "tags": ["Cart"],
        "summary": "Add an item to your cart",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["menu_item_id"],
                "properties": {
                  "menu_item_id": { "type": "string", "format": "uuid" },
                  "quantity": { "type": "integer", "default": 1 },
                  "special_instructions": { "type": "string" },
                  "replace": { "type": "boolean", "default": false, "description": "Confirm swapping carts across restaurants" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Added" }, "409": { "description": "Cart has items from another restaurant" } }
      }
    },
    "/cart/items/{menuItemId}": {
      "put": {
        "tags": ["Cart"],
        "summary": "Update quantity/instructions for a cart item",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "menuItemId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Cart"],
        "summary": "Remove an item from your cart",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "menuItemId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Removed" } }
      }
    },
    "/orders/checkout": {
      "post": {
        "tags": ["Orders"],
        "summary": "Convert your cart into an order and initialize a Paystack payment",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["delivery_address"],
                "properties": {
                  "delivery_address": { "type": "string" },
                  "delivery_lat": { "type": "number" },
                  "delivery_lng": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Order created, includes Paystack authorization_url" } }
      }
    },
    "/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "List your own orders",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Orders" } }
      }
    },
    "/orders/{id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Order detail",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Order" }, "403": { "$ref": "#/components/responses/Forbidden" } }
      }
    },
    "/orders/{id}/status": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Advance order status (restaurant owner/admin)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object", "required": ["status"], "properties": { "status": { "type": "string" } } }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      }
    },
    "/orders/{id}/cancel": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Cancel your order (while pending/confirmed)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Cancelled" } }
      }
    },
    "/payments/webhook": {
      "post": {
        "tags": ["Payments"],
        "summary": "Paystack webhook (signature-verified, not user-authenticated)",
        "responses": { "200": { "description": "Acknowledged" }, "401": { "description": "Invalid signature" } }
      }
    },
    "/payments/verify/{reference}": {
      "get": {
        "tags": ["Payments"],
        "summary": "Manually verify a payment (fallback for the Paystack redirect)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "reference", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Payment status" } }
      }
    },
    "/delivery/{orderId}": {
      "get": {
        "tags": ["Delivery"],
        "summary": "Get delivery tracking for an order",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Tracking info" } }
      }
    },
    "/delivery/{orderId}/assign-agent": {
      "patch": {
        "tags": ["Delivery"],
        "summary": "Assign a delivery agent (restaurant owner/admin)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Assigned" } }
      }
    },
    "/delivery/{orderId}/location": {
      "patch": {
        "tags": ["Delivery"],
        "summary": "Push live location (assigned agent/admin)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" } }
      }
    },
    "/delivery/{orderId}/status": {
      "patch": {
        "tags": ["Delivery"],
        "summary": "Update delivery status (assigned agent/admin)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "orderId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" } }
      }
    },
    "/delivery/my-deliveries": {
      "get": {
        "tags": ["Delivery"],
        "summary": "Your active delivery queue (delivery_agent)",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "Deliveries" } }
      }
    },
    "/delivery/agents/search": {
      "get": {
        "tags": ["Delivery"],
        "summary": "Search delivery agents by phone (restaurant owner/admin)",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "phone", "in": "query", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Matching agents" } }
      }
    },
    "/reviews": {
      "post": {
        "tags": ["Reviews"],
        "summary": "Review a delivered order",
        "security": [{ "cookieAuth": [] }],
        "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Review" } } } },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/reviews/mine": {
      "get": {
        "tags": ["Reviews"],
        "summary": "Your own reviews",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Reviews" } }
      }
    },
    "/reviews/{id}": {
      "put": {
        "tags": ["Reviews"],
        "summary": "Edit your review",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "tags": ["Reviews"],
        "summary": "Delete your review",
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/notifications": {
      "get": {
        "tags": ["Notifications"],
        "summary": "List your notifications",
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          { "name": "unread_only", "in": "query", "schema": { "type": "boolean" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Notifications" } }
      }
    },
    "/notifications/unread-count": {
      "get": {
        "tags": ["Notifications"],
        "summary": "Unread badge count",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "Count" } }
      }
    },
    "/notifications/read-all": {
      "patch": {
        "tags": ["Notifications"],
        "summary": "Mark all as read",
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "Marked" } }
      }
    },
    "/notifications/{id}/read": {
      "patch": {
